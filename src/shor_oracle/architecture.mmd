flowchart TD
  Target["Target oracle: aP + bQ plus P+Q and 2P checks"]
  Algorithm["Algorithm"]
  Optimization["Optimization"]

  Target --> Algorithm
  Target --> Optimization

  Algorithm --> ABI["Preserve input registers: a, b, P, Q"]
  Algorithm --> Outputs["Write outputs: R=aP+bQ, P+Q, and 2P"]
  Algorithm --> ValidDomain["Trusted P and Q are valid order-21 group points"]
  Algorithm --> DecodeP["Decode P as scalar p where P=pG using selected point bits"]
  Algorithm --> DecodeQ["Decode Q as scalar q where Q=qG using selected point bits"]
  Algorithm --> Products["Compute ap=a*p mod 21 and bq=b*q mod 21"]
  Algorithm --> ROut["Write R=(ap+bq)G"]
  Algorithm --> SumOut["Write P+Q=(p+q)G"]
  Algorithm --> DoubleOut["Write 2P=(2p)G"]
  Algorithm --> Uncompute["Uncompute bq, ap, q, and p scratch"]

  ValidDomain --> DecodeP
  ValidDomain --> DecodeQ
  DecodeP --> PLog["5-bit selector table: x0,x2,x4,y3,y4 -> p"]
  DecodeQ --> QLog["5-bit selector table: x0,x2,x4,y3,y4 -> q"]
  PLog --> Products
  QLog --> Products
  Products --> ROut
  PLog --> SumOut
  QLog --> SumOut
  PLog --> DoubleOut
  ROut --> Outputs
  SumOut --> Outputs
  DoubleOut --> Outputs
  Uncompute --> Validation["Trusted validation: oracle correctness, point-add, point-double, input preservation, phase cleanliness, ancilla cleanup"]
  ABI --> Validation
  Outputs --> Validation

  Optimization --> StrategyChange["Change strategy: scalar logs instead of affine A/B point scratch"]
  Optimization --> SelectorDecode["Use five uniquely identifying bits for valid group points"]
  Optimization --> ZeroRows["Skip scalar-product table rows that XOR zero"]
  Optimization --> SmallerTables["Use 10-bit scalar tables instead of 16/22-bit point tables"]
  Optimization --> Score["Score: 94 * sqrt(57292 * 57292) = 5,385,448"]

  StrategyChange --> Products
  SelectorDecode --> PLog
  SelectorDecode --> QLog
  ZeroRows --> Products
  SmallerTables --> ROut
  SmallerTables --> SumOut
  SmallerTables --> DoubleOut
  Score --> Validation
