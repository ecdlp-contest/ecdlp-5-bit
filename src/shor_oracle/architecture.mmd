flowchart TD
  Target["Target oracle: aP + bQ using in-place F_31 field arithmetic"]
  Algorithm["Algorithm"]
  Optimization["Optimization"]

  Target --> Algorithm
  Target --> Optimization

  Algorithm --> Boundary["Submitted editable boundary: field_arithmetic.rs, scalar_strategy.rs, diagram, and memory notes"]
  Algorithm --> Build["Trusted mod.rs, scalar_api.rs, and builder.rs emit the primitive op stream"]
  Algorithm --> Registers["11 public registers: a, b, P, Q, R=aP+bQ"]
  Algorithm --> Curve["Toy curve y^2 = x^3 + 7 over F_31 with order-21 subgroup"]
  Algorithm --> Encoding["Point encoding: five x bits, five y bits, and one infinity flag"]

  Registers --> Preserve["Preserved inputs: a, b, P, Q"]
  Registers --> Outputs["Written output: R = aP + bQ"]

  Build --> Segment["Segmented reversible compute, copy, uncompute"]
  Segment --> ScalarPoint["Scalar multiplication uses dynamic 2^i point-power chains plus controlled affine adds"]
  ScalarPoint --> PowerChain["3-point cleanup pebble: w0=2P then 8P, w1=4P, w2=16P then cleanup 2P; 10 doublings, 5 controlled adds"]
  PowerChain --> Recycle["Clear 2P before making 8P, add 16P from 8P, then turn the 16P slot into a 2P cleanup pebble"]
  Recycle --> InvalidPark["The temporary 16P xor 2P bit pattern is only an output slot and is never used as a point source"]
  ScalarPoint --> ScalarA["Pebbled held point A = aP"]
  ScalarPoint --> ScalarB["Pebbled held point B = bQ"]
  ScalarA --> PointAdd["Affine point-add computes R = A+B"]
  ScalarB --> PointAdd

  PointAdd --> FieldFacade["Trusted opaque field-kernel facade"]
  FieldFacade --> BuilderCircuits["Trusted builder expands field calls into reversible arithmetic circuits"]
  BuilderCircuits --> FieldArithmetic["Editable in-place F_31 arithmetic calls"]
  ScalarPoint --> FieldFacade
  FieldArithmetic --> FieldAdd["add mod 31 with materialized reduced bits and all-ones flag"]
  FieldArithmetic --> FieldSub["subtract mod 31"]
  FieldArithmetic --> FieldMul["multiply mod 31 by controlled cyclic shifts; first term copies directly; const 3 uses x plus rot1(x)"]
  FieldArithmetic --> FieldInv["inverse mod 31 by Fermat exponentiation, with inverse(0)=0 for invalid branches"]
  FieldArithmetic --> FieldMux["compare, zero-test, and mux"]

  Segment --> Cleanup["All non-register arithmetic scratch is restored to zero before reuse"]
  Cleanup --> Ancilla["Ancilla cleanup is verified after public registers are ignored"]

  Optimization --> CurrentShape["Current local shape: 315 qubits, 4,734,423 Toffoli, 3,531,759 T-depth, score 1,288,070,437.5924695"]
  CurrentShape --> Contract["Package boundary allows scalar_strategy.rs scheduling through opaque handles"]
  Contract --> NoPublicWitness["No P+Q or 2P witness lanes are part of the scored ABI"]
  Contract --> NoHiddenWitness["No hidden F_17 or F_19 field-kernel validation shots are run"]
  Contract --> NoLookupTables["Submissions shall not build P/Q subgroup-index tables, direct aP+bQ tables, or replacement point-oracle tables"]
  Contract --> NoFieldTruthTables["Trusted baseline field kernels avoid enumerated truth-table synthesis"]
  Contract --> NoRawBuilder["Editable files cannot access raw qubits, raw ops, raw point registers, or builder segment boundaries"]
  CurrentShape --> Tradeoff["Cleanup-pebble ordering keeps the 3-scratch qubit win and lowers T-depth without changing Toffoli count"]
  Tradeoff --> ReplaceLater["Future work should reduce inverse/multiply field kernels or find a lower-qubit scalar schedule"]

  Preserve --> Validation["Trusted validation"]
  Outputs --> Validation
  FieldArithmetic --> Validation
  Ancilla --> Validation
  Validation --> Checks["9024 Fiat-Shamir oracle shots, input preservation, phase cleanliness, ancilla cleanup"]
  Validation --> Commitments["Package commitments: ops.bin hash plus this architecture diagram hash"]
